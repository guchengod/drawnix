{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "es5",
  "jsxSingleQuote": false,
  "printWidth": 100,
  "ignorePatterns": [
    ".claude/**",
    "**/*.md",
    "package-lock.json",
    "**/*.scss",
    "**/*.css",
    "**/*.html",
    "**/*.yml",
    "**/*.yaml"
  ]
}
